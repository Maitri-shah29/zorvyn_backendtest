{
  "info": {
    "name": "Finance Backend API",
    "description": "Role-based request set for the Finance Data Processing and Access Control Backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "adminEmail", "value": "admin@finance.local" },
    { "key": "adminPassword", "value": "Admin@123" },
    { "key": "analystEmail", "value": "analyst@finance.local" },
    { "key": "analystPassword", "value": "Analyst@123" },
    { "key": "viewerEmail", "value": "viewer@finance.local" },
    { "key": "viewerPassword", "value": "Viewer@123" },
    { "key": "adminToken", "value": "" },
    { "key": "analystToken", "value": "" },
    { "key": "viewerToken", "value": "" },
    { "key": "createdUserId", "value": "" },
    { "key": "recordId", "value": "" }
  ],
  "item": [
    {
      "name": "01 - Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "02 - Auth",
      "item": [
        {
          "name": "Login - Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "pm.collectionVariables.set('adminToken', data.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login - Analyst",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "pm.collectionVariables.set('analystToken', data.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{analystEmail}}\",\n  \"password\": \"{{analystPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login - Viewer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "pm.collectionVariables.set('viewerToken', data.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{viewerEmail}}\",\n  \"password\": \"{{viewerPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "03 - Users (Admin Only)",
      "item": [
        {
          "name": "List Users (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/users"
          }
        },
        {
          "name": "Create User (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "var data = pm.response.json();",
                  "pm.collectionVariables.set('createdUserId', data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Analyst\",\n  \"email\": \"postman.analyst@example.com\",\n  \"password\": \"StrongPass1\",\n  \"role\": \"ANALYST\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": "{{baseUrl}}/api/users"
          }
        },
        {
          "name": "Update User Status (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"INACTIVE\"\n}"
            },
            "url": "{{baseUrl}}/api/users/{{createdUserId}}"
          }
        },
        {
          "name": "List Users (Viewer - Forbidden)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{viewerToken}}" }
            ],
            "url": "{{baseUrl}}/api/users"
          }
        }
      ]
    },
    {
      "name": "04 - Records",
      "item": [
        {
          "name": "Create Record (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "var data = pm.response.json();",
                  "pm.collectionVariables.set('recordId', data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 2500.75,\n  \"type\": \"INCOME\",\n  \"category\": \"Consulting\",\n  \"recordDate\": \"2026-04-04\",\n  \"description\": \"Postman created record\",\n  \"notes\": \"Smoke test\"\n}"
            },
            "url": "{{baseUrl}}/api/records"
          }
        },
        {
          "name": "List Records (Viewer)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{viewerToken}}" }
            ],
            "url": "{{baseUrl}}/api/records?page=1&pageSize=10"
          }
        },
        {
          "name": "List Records (Filter by Type)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{analystToken}}" }
            ],
            "url": "{{baseUrl}}/api/records?type=INCOME&page=1&pageSize=10"
          }
        },
        {
          "name": "Update Record (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Updated from Postman\"\n}"
            },
            "url": "{{baseUrl}}/api/records/{{recordId}}"
          }
        },
        {
          "name": "Delete Record (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/records/{{recordId}}"
          }
        },
        {
          "name": "Create Record (Viewer - Forbidden)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{viewerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100,\n  \"type\": \"EXPENSE\",\n  \"category\": \"Unauthorized\",\n  \"recordDate\": \"2026-04-04\"\n}"
            },
            "url": "{{baseUrl}}/api/records"
          }
        }
      ]
    },
    {
      "name": "05 - Dashboard",
      "item": [
        {
          "name": "Summary (Viewer)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{viewerToken}}" }
            ],
            "url": "{{baseUrl}}/api/dashboard/summary"
          }
        },
        {
          "name": "Insights (Analyst)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{analystToken}}" }
            ],
            "url": "{{baseUrl}}/api/dashboard/insights"
          }
        },
        {
          "name": "Insights (Viewer - Forbidden)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{viewerToken}}" }
            ],
            "url": "{{baseUrl}}/api/dashboard/insights"
          }
        }
      ]
    }
  ]
}
